---
import TestimonialCard from '@/components/ui/TestimonialCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

type TestimonialItem = {
  name: string;
  handle: string;
  text: string;
  avatar?: string;
  platform?: string;
};

interface Props {
  eyebrow?: string;
  heading?: string;
  testimonials?: TestimonialItem[];
}

type ColumnConfig = {
  className: string;
  directionClass: string;
  offset: number;
};

const { eyebrow, heading, testimonials = [] }: Props = Astro.props;

const colorAccents = [
  'border-l-[var(--site-testimonial-1)]',
  'border-l-[var(--site-testimonial-3)]',
  'border-l-[var(--site-testimonial-5)]',
  'border-l-[var(--site-testimonial-2)]',
  'border-l-[var(--site-testimonial-4)]',
  'border-l-[var(--site-testimonial-3)]',
];

const columnConfigs: ColumnConfig[] = [
  { className: 'testimonial-col min-w-0', directionClass: 'testimonial-col-up', offset: 0 },
  { className: 'testimonial-col hidden sm:block', directionClass: 'testimonial-col-down', offset: 2 },
  { className: 'testimonial-col hidden lg:block', directionClass: 'testimonial-col-up-slow', offset: 4 },
];

const columns = columnConfigs.map((config, columnIndex) => ({
  ...config,
  items: testimonials.filter((_, testimonialIndex) => testimonialIndex % columnConfigs.length === columnIndex),
}));
---

<section class="relative py-20 md:py-28" data-reveal aria-label="Testimonials">
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <SectionHeading eyebrow={eyebrow} heading={heading} align="center" />

    <div class="testimonials-wrapper relative" data-testimonials>
      <div class="testimonials-columns testimonials-fade grid h-80 gap-3 overflow-hidden sm:h-[380px] sm:grid-cols-2 lg:h-[440px] lg:grid-cols-3">
        {columns.map((column) => (
          <div class:list={[column.className, column.directionClass]}>
            <div class="flex flex-col gap-3">
              {[...column.items, ...column.items].map((testimonial, i) => (
                <TestimonialCard
                  testimonial={testimonial}
                  accentClass={colorAccents[(i + column.offset) % colorAccents.length]}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-fade {
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  }

  .testimonial-col {
    overflow: hidden;
  }
  .testimonial-col > div {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-play-state: paused;
  }
  .testimonial-col-up > div {
    animation-name: scroll-up;
    animation-duration: 45s;
  }
  .testimonial-col-down > div {
    animation-name: scroll-down;
    animation-duration: 40s;
  }
  .testimonial-col-up-slow > div {
    animation-name: scroll-up;
    animation-duration: 55s;
  }

  :global([data-testimonials-playing]) .testimonial-col > div {
    animation-play-state: running;
    will-change: transform;
  }

  :global([data-testimonials-playing]:hover) .testimonial-col > div,
  :global([data-testimonials-playing]:focus-within) .testimonial-col > div {
    animation-play-state: paused;
  }

  @keyframes scroll-up {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  @keyframes scroll-down {
    from { transform: translateY(-50%); }
    to { transform: translateY(0); }
  }
</style>

<script>
  import { inView } from 'motion';

  type TestimonialsWindow = Window & {
    __bubTestimonialsCleanup?: () => void;
    __bubTestimonialsPageLoadBound?: boolean;
  };

  function initTestimonialsViewport() {
    const testimonialsWindow = window as TestimonialsWindow;
    testimonialsWindow.__bubTestimonialsCleanup?.();
    testimonialsWindow.__bubTestimonialsCleanup = undefined;

    const wrapper = document.querySelector('[data-testimonials]') as HTMLElement | null;
    if (!wrapper) return;

    let wrapperInView = false;
    const reduceMotionMql = window.matchMedia('(prefers-reduced-motion: reduce)');

    function setPlaying(playing: boolean) {
      wrapper.toggleAttribute('data-testimonials-playing', playing);
    }

    function maybePlay() {
      setPlaying(
        wrapperInView &&
        document.visibilityState !== 'hidden' &&
        !reduceMotionMql.matches,
      );
    }

    const handleMotionPreferenceChange = () => {
      maybePlay();
    };

    const handleVisibilityChange = () => {
      maybePlay();
    };

    reduceMotionMql.addEventListener('change', handleMotionPreferenceChange);
    document.addEventListener('visibilitychange', handleVisibilityChange);

    const stopInView = inView(wrapper, () => {
      wrapperInView = true;
      maybePlay();
      return () => {
        wrapperInView = false;
        setPlaying(false);
      };
    }, { margin: '-5% 0px' });

    testimonialsWindow.__bubTestimonialsCleanup = () => {
      stopInView();
      reduceMotionMql.removeEventListener('change', handleMotionPreferenceChange);
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      wrapperInView = false;
      setPlaying(false);
    };
  }

  const testimonialsWindow = window as TestimonialsWindow;

  initTestimonialsViewport();
  if (!testimonialsWindow.__bubTestimonialsPageLoadBound) {
    document.addEventListener('astro:page-load', initTestimonialsViewport);
    testimonialsWindow.__bubTestimonialsPageLoadBound = true;
  }
</script>
