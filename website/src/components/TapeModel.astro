---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { useTranslations, getLangFromUrl } from '@/i18n/utils';


interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string[];
}

const { eyebrow, heading, description = [] }: Props = Astro.props;

type TapeEntry = {
  ts: string;
  kind: 'event' | 'anchor';
  op: string;
  key: string;
  value: string;
  corrects?: string;
};

const tapeEntries: TapeEntry[] = [
  { ts: '14:32:01', kind: 'event',  op: 'user_msg',    key: 'e_101', value: '"explain hooks"' },
  { ts: '14:32:02', kind: 'event',  op: 'build_prompt', key: 'e_102', value: 'system + 12 msgs' },
  { ts: '14:32:04', kind: 'event',  op: 'model_reply',  key: 'e_103', value: '"Hooks are pluggy…"' },
  { ts: '14:32:04', kind: 'event',  op: 'tool_call',    key: 'e_104', value: 'read_docs("hooks")' },
  { ts: '14:32:05', kind: 'event',  op: 'tool_result',  key: 'e_105', value: '{ok: true, lines: 47}' },
  { ts: '14:32:06', kind: 'anchor', op: 'handoff',      key: 'a_001', value: 'phase → correction, owner: agent' },
  { ts: '14:32:06', kind: 'event',  op: 'correction',   key: 'e_106', value: 'supersedes e_103', corrects: 'e_103' },
  { ts: '14:32:07', kind: 'event',  op: 'model_reply',  key: 'e_107', value: '"Updated: Hooks use pluggy…"' },
  { ts: '14:32:08', kind: 'event',  op: 'save_state',   key: 'e_108', value: 'tape flushed ✓' },
];

const entryCount = tapeEntries.filter(e => e.kind === 'event').length;
const anchorCount = tapeEntries.filter(e => e.kind === 'anchor').length;
const COL_COUNT = 5;
const t = useTranslations(getLangFromUrl(Astro.url));
---

<section class="relative py-20 md:py-28" data-reveal aria-label="Tape context model">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">

      <!-- ── Tape visualization ── -->
      <div class="relative order-2 lg:order-1" data-tape-viz>
        <div class="overflow-hidden border border-border bg-card shadow-[var(--site-shadow-elevated)]">

          <!-- Title bar -->
          <div class="flex items-center justify-between border-b border-border px-4 py-2.5 sm:px-5 sm:py-3">
            <span class="font-mono text-[0.65rem] text-muted-foreground/60">~/.bub/tapes/session_a1b2</span>
            <div class="flex items-center gap-1.5">
              <span
                class="tape-live-dot inline-block h-[6px] w-[6px] rounded-full bg-[var(--site-accent-live)] shadow-[0_0_6px_var(--site-accent-live-shadow)]"
                aria-hidden="true"
              ></span>
              <span class="tape-live-label font-mono text-[0.55rem] uppercase tracking-wider">live</span>
            </div>
          </div>

          <!-- Tape log table -->
          <div class="relative overflow-x-auto overflow-y-hidden">
            <div
              class="tape-scan absolute inset-x-0 top-0 h-px z-10 pointer-events-none opacity-0"
              data-tape-scan
              aria-hidden="true"
            ></div>

            <table class="w-full border-collapse font-mono text-[0.62rem] leading-[1.5]" role="log" aria-label="Tape entries">
              <colgroup>
                <col class="w-[66px] max-sm:hidden" />
                <col class="w-[18px]" />
                <col class="w-[104px]" />
                <col class="w-[50px] max-sm:hidden" />
                <col />
              </colgroup>
              <thead>
                <tr data-tape-header class="opacity-0">
                  <th scope="col" class="px-[0.65rem] py-2 text-[0.5rem] font-medium uppercase tracking-[0.1em] text-left whitespace-nowrap text-muted-foreground opacity-40 border-b border-border max-sm:hidden">time</th>
                  <th scope="col" class="px-[0.65rem] py-2 text-[0.5rem] font-medium uppercase tracking-[0.1em] text-left whitespace-nowrap text-muted-foreground opacity-40 border-b border-border" aria-label="kind"></th>
                  <th scope="col" class="px-[0.65rem] py-2 text-[0.5rem] font-medium uppercase tracking-[0.1em] text-left whitespace-nowrap text-muted-foreground opacity-40 border-b border-border">op</th>
                  <th scope="col" class="px-[0.65rem] py-2 text-[0.5rem] font-medium uppercase tracking-[0.1em] text-left whitespace-nowrap text-muted-foreground opacity-40 border-b border-border max-sm:hidden">key</th>
                  <th scope="col" class="px-[0.65rem] py-2 text-[0.5rem] font-medium uppercase tracking-[0.1em] text-left whitespace-nowrap text-muted-foreground opacity-40 border-b border-border">payload</th>
                </tr>
              </thead>
              <tbody>
                {tapeEntries.map((entry, i) => (
                  entry.kind === 'anchor' ? (
                    <tr class="opacity-0 translate-y-2" data-tape-row={i} data-kind="anchor">
                      <td colspan={COL_COUNT} class="px-[0.65rem] py-[0.55rem]">
                        <div class="flex items-center gap-2">
                          <span class="h-px flex-1 bg-[var(--site-accent-signal-rule)]" aria-hidden="true"></span>
                          <span class="tape-anchor-badge inline-flex items-center gap-[0.35rem] border border-[var(--site-accent-signal-border)] bg-[var(--site-accent-signal-bg)] px-[0.6rem] py-[0.2rem] transition-shadow duration-[400ms]">
                            <Icon name="anchor" size={10} class="text-primary" aria-hidden="true" />
                            <span class="font-mono text-[0.58rem] font-semibold uppercase tracking-[0.05em] text-primary">{entry.op}</span>
                            <span class="font-mono text-[0.5rem] text-primary/50 max-sm:hidden">{entry.value}</span>
                          </span>
                          <span class="h-px flex-1 bg-[var(--site-accent-signal-rule)]" aria-hidden="true"></span>
                        </div>
                      </td>
                    </tr>
                  ) : (
                    <tr
                      class="opacity-0 translate-y-2"
                      data-tape-row={i}
                      data-kind="event"
                      data-key={entry.key}
                      data-corrects={entry.corrects ?? ''}
                    >
                      <td class="px-[0.65rem] py-[0.38rem] whitespace-nowrap align-middle tabular-nums text-muted-foreground opacity-35 max-sm:hidden">{entry.ts}</td>
                      <td class="py-[0.38rem] px-0 whitespace-nowrap align-middle text-center">
                        <span
                          class:list={[
                            'inline-block w-[5px] h-[5px] rounded-full align-middle',
                            entry.corrects
                              ? 'bg-primary shadow-[0_0_6px_var(--site-accent-signal-emphasis)]'
                              : 'bg-muted-foreground opacity-25',
                          ]}
                          aria-hidden="true"
                        />
                      </td>
                      <td class:list={['tape-td--op px-[0.65rem] py-[0.38rem] whitespace-nowrap align-middle font-medium', entry.corrects ? 'text-primary' : 'text-foreground']}>
                        {entry.op}
                      </td>
                      <td class="px-[0.65rem] py-[0.38rem] whitespace-nowrap align-middle text-[0.56rem] text-muted-foreground opacity-40 max-sm:hidden">{entry.key}</td>
                      <td class="tape-td--payload px-[0.65rem] py-[0.38rem] whitespace-nowrap align-middle text-muted-foreground opacity-70 max-w-[170px] overflow-hidden text-ellipsis max-sm:max-w-[120px]">
                        {entry.corrects && (
                          <span class="mr-1 border-b border-dashed border-[var(--site-accent-signal-dashed)] pb-px text-[0.56rem] text-primary/70">← {entry.corrects}</span>
                        )}
                        <span>{entry.value}</span>
                      </td>
                    </tr>
                  )
                ))}
              </tbody>
            </table>
          </div>

          <!-- Live cursor -->
          <div class="flex items-center gap-2 px-[0.65rem] py-[0.45rem] opacity-0" data-tape-cursor>
            <span class="tape-cursor-line inline-block w-[1.5px] h-[13px] bg-primary" aria-hidden="true"></span>
            <span class="font-mono text-[0.5rem] text-primary/40">awaiting next entry…</span>
          </div>

          <!-- View assembly indicator -->
          <div
            class="flex flex-wrap items-center justify-between gap-2 border-t border-dashed border-[var(--site-accent-signal-dashed-border)] bg-[var(--site-accent-signal-bg-subtle)] px-3 py-2 font-mono text-[0.55rem] opacity-0"
            data-tape-view
          >
            <div class="flex items-center gap-[0.35rem]">
              <Icon name="layers" size={11} class="text-primary/70" aria-hidden="true" />
              <span class="font-semibold uppercase tracking-[0.06em] text-primary/70">view assembled</span>
            </div>
            <div class="flex items-center gap-[0.35rem] text-muted-foreground opacity-55">
              <span>{entryCount} facts</span>
              <span class="opacity-40">·</span>
              <span>{anchorCount} anchor</span>
              <span class="opacity-40">→</span>
              <span class="text-primary opacity-80">4.2k tokens</span>
            </div>
          </div>

          <!-- Status bar -->
          <div class="flex flex-wrap items-center gap-2 px-3 py-[0.55rem] border-t border-border font-mono">
            <span class="inline-flex items-center bg-[var(--site-accent-signal-bg-strong)] px-[0.4rem] py-[0.1rem] text-[0.56rem] font-bold text-primary">{entryCount + anchorCount} entries</span>
            <span class="text-[0.56rem] text-muted-foreground opacity-55">{anchorCount} anchor</span>
            <span class="text-[0.52rem] text-muted-foreground opacity-35">·</span>
            <span class="text-[0.52rem] text-muted-foreground opacity-35">append-only</span>
          </div>
        </div>
      </div>

      <!-- ── Text content ── -->
      <div class="order-1 lg:order-2">
        <SectionHeading
          eyebrow={eyebrow}
          heading={heading}
          descriptions={description}
          descriptionsClass="mt-5"
          class="mb-0 max-w-none"
        />
        <a
          href="https://tape.systems/"
          target="_blank"
          rel="noreferrer"
          class="group mt-6 inline-flex items-center gap-1.5 font-mono text-[0.7rem] text-muted-foreground transition-colors hover:text-primary"
        >
          {t('tapeModel.learnMore')}
          <Icon name="arrowUpRight" size={12} class="opacity-50 transition-opacity group-hover:opacity-100" aria-hidden="true" />
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Scan line gradient (complex — kept out of Tailwind arbitrary values) ── */
  .tape-scan {
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--site-accent-signal-soft) 20%,
      var(--site-accent-signal) 50%,
      var(--site-accent-signal-soft) 80%,
      transparent 100%
    );
    box-shadow: 0 0 8px var(--site-accent-signal-shadow);
  }

  /* ── Animations ── */
  .tape-live-dot,
  .tape-cursor-line {
    animation-play-state: paused;
  }
  .tape-live-dot {
    box-shadow: 0 0 6px var(--site-accent-live-shadow);
  }
  [data-tape-running] .tape-live-dot {
    animation: live-pulse 2s ease-in-out infinite;
  }
  [data-tape-running] .tape-cursor-line {
    animation: cursor-blink 1s ease-in-out infinite;
  }
  .tape-live-label { color: var(--site-accent-live); opacity: 0.8; }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.45; }
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── JS-applied dynamic states ── */
  .tape-row-superseded .tape-td--payload span:last-child {
    text-decoration: line-through;
    text-decoration-color: var(--site-accent-signal-emphasis);
    opacity: 0.3;
    transition: opacity 0.4s ease, text-decoration-color 0.4s ease;
  }
  .tape-row-superseded .tape-td--op {
    opacity: 0.3;
    transition: opacity 0.4s ease;
  }
  .tape-anchor-glow .tape-anchor-badge {
    box-shadow: 0 0 16px var(--site-accent-signal-shadow);
  }
  .tape-row-highlight {
    background: var(--site-accent-signal-bg);
    transition: background 0.4s ease;
  }
</style>

<script>
  import { animate, stagger, inView } from 'motion';

  type TapeAnimationWindow = Window & {
    __bubTapeAnimationCleanup?: () => void;
    __bubTapeAnimationPageLoadBound?: boolean;
  };

  function initTapeAnimation() {
    const tapeAnimationWindow = window as TapeAnimationWindow;
    tapeAnimationWindow.__bubTapeAnimationCleanup?.();
    tapeAnimationWindow.__bubTapeAnimationCleanup = undefined;

    const viz = document.querySelector('[data-tape-viz]');
    if (!viz) return;

    const header = viz.querySelector('[data-tape-header]') as HTMLElement | null;
    const rows = Array.from(viz.querySelectorAll('[data-tape-row]')) as HTMLElement[];
    const scan = viz.querySelector('[data-tape-scan]') as HTMLElement | null;
    const viewEl = viz.querySelector('[data-tape-view]') as HTMLElement | null;
    const cursor = viz.querySelector('[data-tape-cursor]') as HTMLElement | null;

    if (!rows.length) return;

    const GAP = 0.15;
    const BASE = 0.15;
    const ENTRANCE_END = BASE + rows.length * GAP + 0.4;
    const HOLD = 3.5;
    const FADE = 0.45;
    const PAUSE = 1;

    let active = false;
    let timers: number[] = [];
    let controls: Array<{ stop: () => void }> = [];

    function setRunning(running: boolean) {
      viz.toggleAttribute('data-tape-running', running);
    }

    function sched(fn: () => void, ms: number) {
      timers.push(window.setTimeout(() => { if (active) fn(); }, ms));
    }

    function runAnimation(
      target: Parameters<typeof animate>[0],
      keyframes: Parameters<typeof animate>[1],
      options: Parameters<typeof animate>[2],
    ) {
      const control = animate(target, keyframes, options);
      controls.push(control);
      return control;
    }

    function stopAnimations() {
      controls.forEach((control) => control.stop());
      controls = [];
    }

    function clearTimers() {
      timers.forEach(clearTimeout);
      timers = [];
    }

    function reset() {
      stopAnimations();
      setRunning(false);
      if (header) header.style.opacity = '0';
      rows.forEach(r => {
        r.style.opacity = '0';
        r.style.transform = 'translateY(8px)';
        r.classList.remove('tape-row-superseded', 'tape-row-highlight', 'tape-anchor-glow');
      });
      if (viewEl) {
        viewEl.style.opacity = '0';
        viewEl.style.transform = 'translateY(6px)';
      }
      if (cursor) cursor.style.opacity = '0';
      if (scan) {
        scan.style.opacity = '0';
        scan.style.transform = 'translateY(0)';
      }
    }

    function cycle() {
      if (!active) return;
      clearTimers();
      reset();
      setRunning(true);

      // ─ Phase 1: header
      sched(() => {
        if (header) runAnimation(header, { opacity: [0, 1] }, { duration: 0.3, ease: 'ease-out' });
      }, 60);

      // ─ Phase 2: staggered rows
      sched(() => {
        runAnimation(
          rows,
          { opacity: [0, 1], y: [10, 0] },
          { delay: stagger(GAP, { start: BASE }), duration: 0.4, ease: [0.22, 1, 0.36, 1] }
        );
      }, 80);

      // ─ Phase 3: per-row effects
      rows.forEach((row, i) => {
        const ms = (BASE + i * GAP) * 1000 + 80;

        if (row.dataset.kind === 'anchor') {
          sched(() => {
            const badge = row.querySelector('.tape-anchor-badge') as HTMLElement | null;
            if (badge) {
              runAnimation(badge, { scale: [0.85, 1.05, 1] }, { duration: 0.55, ease: [0.22, 1, 0.36, 1] });
              row.classList.add('tape-anchor-glow');
              sched(() => row.classList.remove('tape-anchor-glow'), 1500);
            }
          }, ms);
        }

        if (row.dataset.corrects) {
          sched(() => {
            const key = row.dataset.corrects!;
            const superseded = viz.querySelector(`[data-key="${key}"]`) as HTMLElement | null;
            if (superseded) superseded.classList.add('tape-row-superseded');
            row.classList.add('tape-row-highlight');
            sched(() => row.classList.remove('tape-row-highlight'), 1400);
          }, ms + 200);
        }
      });

      // ─ Phase 4: scan line
      sched(() => {
        if (!scan) return;
        const h = scan.parentElement?.scrollHeight ?? 300;
        runAnimation(scan, { opacity: [0, 0.7, 0.7, 0], y: [0, 0, h, h] }, { duration: 1.3, ease: [0.4, 0, 0.2, 1] });
      }, (ENTRANCE_END + 0.15) * 1000);

      // ─ Phase 5: cursor
      sched(() => {
        if (cursor) runAnimation(cursor, { opacity: [0, 1] }, { duration: 0.4, ease: 'ease-out' });
      }, (ENTRANCE_END + 0.5) * 1000);

      // ─ Phase 6: view assembly
      sched(() => {
        if (viewEl) runAnimation(viewEl, { opacity: [0, 1], y: [6, 0] }, { duration: 0.5, ease: [0.22, 1, 0.36, 1] });
      }, (ENTRANCE_END + 1.2) * 1000);

      // ─ Phase 7: hold → fade out → loop
      const fadeAt = (ENTRANCE_END + 1.8 + HOLD) * 1000;
      sched(() => {
        const all = [header, ...rows, viewEl, cursor].filter(Boolean) as HTMLElement[];
        runAnimation(all, { opacity: 0 }, { duration: FADE, ease: 'ease-in' });
        sched(() => cycle(), (FADE + PAUSE) * 1000);
      }, fadeAt);
    }

    const stopInView = inView(viz, () => {
      active = true;
      cycle();
      return () => {
        active = false;
        clearTimers();
        reset();
      };
    }, { margin: '-20% 0px -20% 0px' });

    tapeAnimationWindow.__bubTapeAnimationCleanup = () => {
      stopInView();
      active = false;
      clearTimers();
      reset();
    };
  }

  const tapeAnimationWindow = window as TapeAnimationWindow;

  initTapeAnimation();
  if (!tapeAnimationWindow.__bubTapeAnimationPageLoadBound) {
    document.addEventListener('astro:page-load', initTapeAnimation);
    tapeAnimationWindow.__bubTapeAnimationPageLoadBound = true;
  }
</script>
